# ==============================================================================
# SGE FORTAL - Configurações de Ambiente (Staging / Produção / Local)
# ==============================================================================

# 1. Banco de Dados PostgreSQL (Obrigatório)
# Deve apontar para o host do banco de dados (ex: db no docker-compose)
DATABASE_URL="postgresql://admin:fortalpassword@127.0.0.1:5433/fortal_sge?schema=public"

# 2. Redis / Filas Assíncronas (BullMQ) (Obrigatório)
# Necessário para o recálculo assíncrono do Custo Médio Ponderado (ReceiveBatch)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# 3. Autenticação e Segurança (Obrigatório)
# Chave secreta para assinar o payload do JWT. EM PRODUÇÃO, USE UMA CHAVE FORTE (ex: 64 chars aleatórios)
JWT_SECRET="sge-fortal-secret-dev-key-2026"
JWT_EXPIRATION="15m"

# 4. Aplicação / API
PORT=3000
NODE_ENV="development" # Em staging, mude para "staging" ou "production"
