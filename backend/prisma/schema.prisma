generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  senha    String
  perfil   String // RBAC: 'ADMIN', 'GESTOR', 'OPERADOR'
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())

  movimentacoes Movimentacao[]
  ajustesSolicitados AjusteEstoque[] @relation("AjusteSolicitante")
  ajustesAprovados   AjusteEstoque[] @relation("AjusteAprovador")
  contagens          ContagemInventario[]
  pedidosConferidos1 PedidoExpedicao[] @relation("ConferenteUm")
  pedidosConferidos2 PedidoExpedicao[] @relation("ConferenteDois")
}

model Produto {
  id         Int     @id @default(autoincrement())
  sku        String  @unique
  descricao  String
  categoria  String
  perecivel  Boolean @default(false)
  tipoZonaRequerida String @default("SECO") // 'SECO', 'REFRIGERADO', 'CONGELADO' (RN-ARM-003)
  custoMedio Float   @default(0.0) // Atualizado no Recebimento (RN-CST-001)
  ativo      Boolean @default(true) // Soft delete (RN-TRV-003)

  lotes Lote[]
  logsCusto LogCusto[]
  itensPedido ItemPedido[]
}

model NotaFiscal {
  id            Int      @id @default(autoincrement())
  chaveAcesso   String   @unique // 44 dígitos - RN-REC-002 (impede duplicidade)
  numero        String
  serie         String
  cnpjEmitente  String
  dataEmissao   DateTime
  valorTotal    Float
  xmlOriginal   String   @db.Text // XML bruto para auditoria (RN-REL-001)
  status        String   @default("PENDENTE") // 'PENDENTE', 'CONFERIDO', 'DIVERGENTE'
  divergencias  String?  @db.Text // JSON com apontamentos de divergência (RN-REC-001)
  criadoEm      DateTime @default(now())

  itensNfe ItemNfe[]
  lotes    Lote[]
}

model ItemNfe {
  id             Int    @id @default(autoincrement())
  notaFiscalId   Int
  produtoSku     String // SKU/EAN do item conforme NF-e
  descricaoNfe   String // Descrição do produto na NF-e
  quantidade     Int
  valorUnitario  Float
  valorTotal     Float

  notaFiscal NotaFiscal @relation(fields: [notaFiscalId], references: [id])
}

model Lote {
  id           Int       @id @default(autoincrement())
  numeroLote   String
  produtoId    Int
  quantidade   Int       @default(0) // Central de saldo
  validade     DateTime?
  ativo        Boolean   @default(true) // Soft delete
  emInventario Boolean   @default(false) // RN-INV-006: Bloqueio logico
  notaFiscalId Int? // Vínculo com NF-e de origem
  evidenciaUrl String? // RN-REC-003: Foto evidência (obrigatório se perecível)

  produto       Produto         @relation(fields: [produtoId], references: [id])
  notaFiscal    NotaFiscal?     @relation(fields: [notaFiscalId], references: [id])
  movimentacoes Movimentacao[]
  ajustes       AjusteEstoque[]
  contagens     ContagemInventario[]
}

model Endereco {
  id         Int     @id @default(autoincrement())
  codigo     String  @unique // ex: A-01-01
  zona       String
  tipoZona   String  @default("SECO") // 'SECO', 'REFRIGERADO', 'CONGELADO' (RN-ARM-003)
  capacidade Int
  ocupado    Int     @default(0)
  ativo      Boolean @default(true)

  movimentacoesOrigem  Movimentacao[] @relation("EnderecoOrigem")
  movimentacoesDestino Movimentacao[] @relation("EnderecoDestino")
}

model Movimentacao {
  id                Int      @id @default(autoincrement())
  tipo              String // 'ENTRADA', 'SAIDA', 'AJUSTE', 'INVENTARIO'
  loteId            Int
  quantidade        Int
  motivo            String?
  enderecoOrigemId  Int?
  enderecoDestinoId Int?
  usuarioId         Int
  criadoEm          DateTime @default(now()) // Carimbo de tempo NTP (RN-TRV-005)
  hash              String
  previousHash      String?

  lote            Lote      @relation(fields: [loteId], references: [id])
  enderecoOrigem  Endereco? @relation("EnderecoOrigem", fields: [enderecoOrigemId], references: [id])
  enderecoDestino Endereco? @relation("EnderecoDestino", fields: [enderecoDestinoId], references: [id])
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
}

model AjusteEstoque {
  id              Int      @id @default(autoincrement())
  loteId          Int
  quantidadeDelta Int
  motivo          String
  valorDelta      Float    @default(0.0)
  statusAprovacao String   @default("PENDENTE") // 'PENDENTE', 'APROVADO', 'REJEITADO'
  solicitanteId   Int
  aprovadorId     Int?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  lote        Lote     @relation(fields: [loteId], references: [id])
  solicitante Usuario  @relation("AjusteSolicitante", fields: [solicitanteId], references: [id])
  aprovador   Usuario? @relation("AjusteAprovador", fields: [aprovadorId], references: [id])
}

model LogCusto {
  id                 Int      @id @default(autoincrement())
  produtoId          Int
  custoAnterior      Float
  custoNovo          Float
  quantidadeAnterior Int
  quantidadeNova     Int
  motivo             String?
  criadoEm           DateTime @default(now())
  hash               String
  previousHash       String?

  produto Produto @relation(fields: [produtoId], references: [id])
}

model ContagemInventario {
  id                Int      @id @default(autoincrement())
  loteId            Int
  quantidadeFisica  Int?
  quantidadeTeorica Int
  status            String   @default("PENDENTE") // 'PENDENTE', 'CONCLUIDO', 'DIVERGENTE', 'AJUSTADO'
  usuarioId         Int
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  lote    Lote    @relation(fields: [loteId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model PedidoExpedicao {
  id            Int      @id @default(autoincrement())
  codigoPedido  String   @unique // Código do ERP ou sistema externo
  status        String   @default("PENDENTE") // 'PENDENTE', 'SEPARACAO', 'CONFERIDO', 'EXPEDIDO'
  valorTotal    Float    @default(0.0) // Usado para RN-EXP-003
  conferente1Id Int?
  conferente2Id Int?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  itens       ItemPedido[]
  conferente1 Usuario?     @relation("ConferenteUm", fields: [conferente1Id], references: [id])
  conferente2 Usuario?     @relation("ConferenteDois", fields: [conferente2Id], references: [id])
}

model ItemPedido {
  id                   Int      @id @default(autoincrement())
  pedidoId             Int
  produtoId            Int
  quantidadeSolicitada Int
  quantidadeSeparada   Int      @default(0) // Preenchido durante o picking

  pedido  PedidoExpedicao @relation(fields: [pedidoId], references: [id])
  produto Produto         @relation(fields: [produtoId], references: [id])
}

